# Kopiraj ovaj fajl u .env na hostingu i popuni vrednosti
# Na hostingu: preimenuj u .env

APP_NAME="NPM Enterijeri"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tvoj-domen.rs

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
